# Neon: pooled connection (recommended for the app runtime)
# Create project at https://neon.tech — paste full URL from Neon dashboard (never commit real credentials).
# Example shape (replace USER, PASSWORD, HOST, DB):
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# Optional: unpooled/direct URL for `prisma migrate` if Neon provides it (set only if migrations fail via pooler)
# DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

JWT_SECRET=change-me-in-production

PORT=3000

# Comma-separated browser origins allowed to call this API
CORS_ORIGINS=http://localhost:8080
