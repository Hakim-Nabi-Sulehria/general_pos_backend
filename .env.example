# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Required in production — use a long random string
JWT_SECRET=change-me-in-production

# HTTP port (Render/Railway often set PORT automatically)
PORT=3000

# Comma-separated list of allowed browser origins (your deployed frontend).
# If unset, defaults to http://localhost:8080 and http://localhost:3000
# Example: https://my-app.vercel.app,https://www.my-app.com
CORS_ORIGINS=http://localhost:8080
